{
  "version": 1,
  "sdk_version": "0.22.2",
  "path": "/functions/v1/mcp",
  "auth": {
    "type": "oauth",
    "issuer": "https://gperaijwlecreqxoygjy.supabase.co/auth/v1",
    "accepted_audiences": [
      "authenticated"
    ]
  },
  "mcp": {
    "server": {
      "name": "rumifield-mcp",
      "version": "0.2.0",
      "title": "RumiField MCP - Oficina"
    },
    "tools": [
      {
        "name": "whoami",
        "title": "Quem sou eu",
        "description": "Retorna o usuário autenticado que está chamando o MCP (id e email).",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {}
        },
        "outputSchema": null
      },
      {
        "name": "list_activities",
        "title": "Listar Atividades da Oficina",
        "description": "Lista tipos de atividade cadastrados (para uso como filtro em outras ferramentas).",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {}
        },
        "outputSchema": null
      },
      {
        "name": "list_work_orders",
        "title": "Listar OS da Oficina",
        "description": "Lista Ordens de Serviço da oficina visíveis ao usuário (respeita RLS). Filtros por status, cliente, atividade e intervalo de datas (created_at).",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "status": {
              "type": "string",
              "enum": [
                "aguardando",
                "em_manutencao",
                "concluido"
              ]
            },
            "cliente_id": {
              "type": "string",
              "format": "uuid"
            },
            "activity_id": {
              "type": "string",
              "format": "uuid"
            },
            "date_from": {
              "type": "string",
              "description": "ISO date (inclusive) para created_at."
            },
            "date_to": {
              "type": "string",
              "description": "ISO date (inclusive) para created_at."
            },
            "limit": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "description": "Padrão 20, máx 100."
            }
          },
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "get_work_order",
        "title": "Detalhar OS",
        "description": "Retorna detalhes de uma OS: itens, peças usadas e apontamentos de tempo.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string",
              "format": "uuid"
            },
            "os_code": {
              "type": "string"
            }
          },
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "list_workshop_items",
        "title": "Ativos da Oficina (Saúde de Motores)",
        "description": "Lista ativos (workshop_items). Com only_with_motor=true, retorna apenas ativos com motor vinculado e calcula horas de uso do motor atual (meter_hours_last - motor_replaced_at_meter_hours).",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "only_with_motor": {
              "type": "boolean"
            },
            "min_motor_hours": {
              "type": "number",
              "description": "Filtra motores com horas de uso >= este valor."
            },
            "limit": {
              "type": "integer",
              "minimum": 1,
              "maximum": 200
            }
          },
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "list_motor_replacements",
        "title": "Histórico de Trocas de Motor",
        "description": "Últimas trocas de motor. Filtros opcionais por intervalo de datas (replaced_at) e workshop_item_id.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "workshop_item_id": {
              "type": "string",
              "format": "uuid"
            },
            "date_from": {
              "type": "string"
            },
            "date_to": {
              "type": "string"
            },
            "limit": {
              "type": "integer",
              "minimum": 1,
              "maximum": 200
            }
          },
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      }
    ]
  }
}
